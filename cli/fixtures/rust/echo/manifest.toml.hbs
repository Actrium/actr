edition = 1
exports = []

[package]
name = "{{PROJECT_NAME_PASCAL}}ClientApp"
manufacturer = "{{MANUFACTURER}}"
version = "1.0.0"
description = "Package-backed Rust echo client app"
authors = []
license = "Apache-2.0"
tags = ["dev", "app"]

[dependencies]
EchoService = { actr_type = "{{MANUFACTURER}}:EchoService:1.0.0" }

[binary]
path = "dist/app.wasm"
target = "wasm32-unknown-unknown"

[build]
tool = "cargo"
manifest_path = "Cargo.toml"
artifact = "lib"
profile = "release"
target = "wasm32-unknown-unknown"
post_build = [
  'mkdir -p "$(dirname "$ACTR_BUILD_BINARY_PATH")" && if command -v "${WASM_OPT:-wasm-opt}" >/dev/null 2>&1; then "${WASM_OPT:-wasm-opt}" --asyncify -O "target/wasm32-unknown-unknown/release/{{PROJECT_NAME_SNAKE}}_guest.wasm" -o "$ACTR_BUILD_BINARY_PATH"; else cp "target/wasm32-unknown-unknown/release/{{PROJECT_NAME_SNAKE}}_guest.wasm" "$ACTR_BUILD_BINARY_PATH"; fi',
]

[scripts]
dev = "cargo run"
