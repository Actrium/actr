//! {{PROJECT_NAME}} — Actor-RTC echo client
//!
//! This scaffold is client-only. Discover a remote service and call it directly.

use anyhow::Result;
use tracing::info;

use actr::prelude::*;

#[tokio::main]
async fn main() -> Result<()> {
    info!("{} starting", env!("CARGO_PKG_NAME"));

    let config = actr::config::ConfigParser::from_file("actr.toml")?;
    let hyper = Hyper::init(HyperConfig::new(config.config_dir.join(".hyper"))).await?;
    let node = hyper.attach_none(config).await?;
    let actr_ref = node.start().await?;

    info!("Client started with id {}", actr_ref.actor_id().to_string_repr());
    Ok(())
}
