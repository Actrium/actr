//! {{PROJECT_NAME}} — Actor-RTC EchoService provider
//!
//! Run `actr gen -l rust` to populate `src/generated/` before building.
//!
//! Usage: cargo run
//!   Registers the EchoService actor, waits for RPC calls, and echoes messages back.

mod generated;
mod echo_service;

use std::path::PathBuf;
use tracing::info;

use actr_runtime::prelude::*;

use crate::generated::echo_actor::EchoServiceWorkload;
use echo_service::EchoServiceImpl;

#[tokio::main]
async fn main() -> anyhow::Result<()> {
    let config_path = PathBuf::from(env!("CARGO_MANIFEST_DIR")).join("Actr.toml");
    let config = actr_config::ConfigParser::from_file(&config_path)?;

    let _obs_guard = actr_runtime::init_observability(&config.observability)?;

    info!("🚀 {} starting (EchoService)", env!("CARGO_PKG_NAME"));

    let system = ActrSystem::new(config).await?;
    let _actr_ref = system
        .attach(EchoServiceWorkload::new(EchoServiceImpl::new()))
        .start()
        .await?;

    info!("✅ EchoService registered, waiting for RPC calls...");

    tokio::signal::ctrl_c().await?;
    info!("Shutting down");
    Ok(())
}
