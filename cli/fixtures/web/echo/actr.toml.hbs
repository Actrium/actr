edition = 1
exports = []

[package]
name = "echo-client-app"
manufacturer = "{{MANUFACTURER}}"
description = "Actor-RTC Web echo client app"
authors = []
license = "Apache-2.0"
tags = ["dev", "client"]

[dependencies]
{{#if IS_BOTH}}
EchoService = { type = "{{MANUFACTURER}}:EchoService" }
{{else}}
EchoService = { type = "{{MANUFACTURER}}:EchoService" }
{{/if}}

# Web platform configuration
[platform.web]
generate_types = true
types_output = "./src/generated/types"
worker_type = "service-worker"
service_worker_path = "./public/actor.sw.js"
generate_sw_entry = true

[system.signaling]
url = "{{{SIGNALING_URL}}}/signaling/ws"

[system.ais_endpoint]
url = "{{{AIS_ENDPOINT_URL}}}"

[system.deployment]
realm_id = {{REALM_ID}}

[system.discovery]
visible = true

[system.observability]
filter_level = "info"
tracing_enabled = false

[system.webrtc]
stun_urls = {{{STUN_URLS}}}
turn_urls = {{{TURN_URLS}}}

[scripts]
dev = "npm run dev"
build-wasm = "cd wasm && bash build.sh"

[acl]

[[acl.rules]]
permission = "allow"
types = ["{{MANUFACTURER}}:EchoService"]