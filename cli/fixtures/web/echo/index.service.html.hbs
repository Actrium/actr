<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{PROJECT_NAME}} - Actor-RTC Web Server</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      max-width: 800px;
      margin: 50px auto;
      padding: 20px;
      background: #1a1a2e;
      color: #e0e0e0;
    }
    h1 { color: #28a745; }
    .status { padding: 12px; border-radius: 8px; margin-bottom: 16px; }
    .status.connecting { background: rgba(255,193,7,0.2); color: #ffc107; }
    .status.connected { background: rgba(40,167,69,0.2); color: #28a745; }
    .status.error { background: rgba(220,53,69,0.2); color: #dc3545; }
    #result { background: #111; padding: 16px; border-radius: 8px; min-height: 200px; max-height: 400px; overflow-y: auto; font-family: monospace; font-size: 13px; }
  </style>
</head>
<body>
  <h1>{{PROJECT_NAME}}</h1>
  <p>Actor-RTC Web EchoService</p>
  <div id="status" class="status connecting">Starting...</div>
  <div id="result"></div>
  <script type="module" src="/src/main.ts"></script>
</body>
</html>
