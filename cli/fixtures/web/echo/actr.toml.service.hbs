edition = 1
exports = ["protos/local/echo.proto"]

[package]
name = "{{PROJECT_NAME}}"
description = "Actor-RTC Web EchoService provider"
authors = []
license = "Apache-2.0"
tags = ["dev", "server"]

[package.actr_type]
manufacturer = "{{MANUFACTURER}}"
name = "EchoService"

[dependencies]

# Web platform configuration
[platform.web]
generate_types = true
types_output = "./src/generated"
worker_type = "service-worker"
service_worker_path = "/actor.sw.js"
generate_sw_entry = true

[system.signaling]
url = "{{{SIGNALING_URL}}}/signaling/ws"

[system.deployment]
realm_id = {{REALM_ID}}

[system.discovery]
visible = true

[system.observability]
filter_level = "info"
tracing_enabled = false

[system.webrtc]
stun_urls = {{{STUN_URLS}}}
turn_urls = {{{TURN_URLS}}}

[scripts]
dev = "npm run dev"
build-wasm = "cd wasm && bash build.sh"

[acl]

[[acl.rules]]
permission = "allow"
types = ["{{MANUFACTURER}}:echo-client-app"]
