/**
 * {{PROJECT_NAME}} - Actor-RTC Web Echo Server
 *
 * Uses @actr/web unified Actor API to create a browser-side service:
 * 1. Create Actor (loads WASM with EchoService in Service Worker)
 * 2. WASM Service Worker handles incoming RPC requests
 * 3. Service Worker broadcasts events to main page for UI updates
 */

import { createActor, type Actor } from '@actr/web';
import { actrConfig, actorType, system } from './generated';

const statusEl = document.getElementById('status')!;
const resultEl = document.getElementById('result')!;

let actor: Actor | null = null;

function log(message: string): void {
  const time = new Date().toLocaleTimeString();
  const entry = document.createElement('div');
  entry.textContent = `[${time}] ${message}`;
  resultEl.appendChild(entry);
  resultEl.scrollTop = resultEl.scrollHeight;
}

function setupSwEventListener(): void {
  navigator.serviceWorker.addEventListener('message', (event) => {
    const data = event.data;
    if (!data || !data.type) return;

    if (data.type === 'echo_event') {
      log(`${data.event}: ${data.detail}`);
    } else if (data.type === 'sw_log') {
      log(`[SW ${data.level}] ${data.message}`);
    }
  });
}

async function init(): Promise<void> {
  statusEl.textContent = `Starting ${actorType.fullType}...`;
  statusEl.className = 'status connecting';

  log(`Signaling: ${system.signaling.url}`);
  log(`Realm: ${system.deployment.realm_id}`);
  log(`ActorType: ${actorType.fullType}`);

  setupSwEventListener();

  try {
    actor = await createActor(actrConfig);
    statusEl.textContent = `${actorType.name} running`;
    statusEl.className = 'status connected';
    log('EchoService started, waiting for incoming requests...');
  } catch (error) {
    statusEl.textContent = `Error: ${error}`;
    statusEl.className = 'status error';
    log(`Start failed: ${error}`);
  }
}

init();
