edition = 1
exports = []

[package]
name = "echo-client-app"
manufacturer = "{{MANUFACTURER}}"
description = "Shell echo client (Python demo)"
authors = []
license = "Apache-2.0"
tags = ["dev", "example", "python"]

[system.signaling]
url = "{{{SIGNALING_URL}}}/signaling/ws"

[system.webrtc]
force_relay = false
stun_urls = ["stun:127.0.0.1:3478"]
turn_urls = ["turn:127.0.0.1:3478"]

[system.deployment]
realm_id = 0

[system.discovery]
visible = true

[dependencies]
EchoService = {}

[acl]

[[acl.rules]]
permission = "allow"
principals = [{ actr_type = { manufacturer = "{{MANUFACTURER}}", name = "EchoService" } }]

[scripts]
dev = "python client.py --manifest manifest.toml client-1 \"hello\""
