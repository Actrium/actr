import { ActrNode, PayloadType } from '@actor-rtc/actr';
{{#if IS_BOTH}}
import { EchoRequest } from './generated/{{SERVICE_NAME}}/echo_client';
{{else}}
import { EchoRequest } from './generated/echo-echo-server/echo_client';
{{/if}}

const RPC_TIMEOUT_MS = 15000;
const RPC_PAYLOAD_TYPE: PayloadType = PayloadType.RpcReliable;

async function main(): Promise<void> {
  const node = await ActrNode.fromConfig('./actr.toml');
  const actorRef = await node.start();

  const [target] = await actorRef.discover(
    {
      manufacturer: 'actrium',
      name: 'EchoService',
      version: process.env.ECHO_ACTR_VERSION ?? '0.2.1-beta',
    },
    1,
  );

  if (!target) {
    throw new Error('No EchoService target discovered');
  }

  const req = EchoRequest.encode({ message: 'hello' });
  const responseBytes = await actorRef.call(
    target,
    EchoRequest.routeKey,
    RPC_PAYLOAD_TYPE,
    req,
    RPC_TIMEOUT_MS,
  );
  const response = EchoRequest.response.decode(responseBytes);
  console.log('Echo reply:', response.reply);

  await actorRef.stop();
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
