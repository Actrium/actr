{
  "name": "actr-example-echo-workload-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Actr echo workload authored in TypeScript, compiled to a wasm32-wasip2 Component via ComponentizeJS (StarlingMonkey).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "./build.sh",
    "build:ts": "tsc",
    "build:component": "jco componentize dist/workload.js --wit ../../../core/framework/wit/actr-workload.wit --world-name actr-workload-guest --out echo.wasm",
    "verify": "wasm-tools component wit echo.wasm",
    "clean": "rm -rf dist node_modules echo.wasm"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "1.18.1",
    "@bytecodealliance/componentize-js": "0.20.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
